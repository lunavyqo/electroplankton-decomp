# Normalize text; keep scripts portable across macOS/Windows/Linux.
* text=auto

*.py  text eol=lf
*.sh  text eol=lf
*.md  text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.c   text eol=lf
*.h   text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf
*.s   text eol=lf
*.S   text eol=lf
*.ld  text eol=lf
*.inc text eol=lf

# Never treat ROMs or binaries as text
*.nds binary
*.bin binary
*.sdat binary
*.wav binary
*.png binary
*.o   binary
*.elf binary
